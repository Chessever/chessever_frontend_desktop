# ChessEver Desktop — contributor environment template
#
#   cp .env.example .env
#
# The values filled in below are PUBLIC keys that already ship inside every
# released build, so distributing them leaks nothing. With these alone the
# desktop app builds and reads public data.
#
# The desktop reaches the large historical game database through a hosted
# Supabase Edge Function proxy (gamebase-proxy), which keeps the upstream
# Gamebase API key server-side. You therefore do NOT need a Gamebase key to run
# the desktop app. To manage developer access, see:
#   https://chessever.com/developers

# --- Public, prefilled (safe to use as-is) -----------------------------------

SUPABASE_URL=https://oelbsuggrzyqwzmvidju.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9lbGJzdWdncnp5cXd6bXZpZGp1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDk5MDgyODYsImV4cCI6MjA2NTQ4NDI4Nn0.YpIEGIVCN2yUmh4ALnuF0i4jKI3ld1VHNVSCN2J7R30
GOOGLE_WEB_CLIENT_ID=882734779574-4pttdbmj67d2044ag6kcq9n3rsao6k29.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=882734779574-8v68and9jcueedkvk0dl2ftse6dn8kt3.apps.googleusercontent.com

# --- Desktop Google sign-in (optional in local dev) --------------------------
# Needed only to test Google sign-in on the desktop OAuth flow. The client
# secret is not distributed; the app still runs and reads public data without
# it. Ask a maintainer if you need to work on desktop auth.
GOOGLE_DESKTOP_CLIENT_ID=
GOOGLE_DESKTOP_CLIENT_SECRET=

# --- Overrides (leave blank to use the hosted defaults) ----------------------
# Crash reporting. Leave blank in local dev so your activity stays out of
# production dashboards.
SENTRY_FLUTTER=
# Billing API base. Blank derives <SUPABASE_URL>/functions/v1 automatically.
BILLING_API_BASE=
# Gamebase proxy base. Blank derives <SUPABASE_URL>/functions/v1/gamebase-proxy
# automatically, so historical search works with the public keys above.
GAMEBASE_PROXY_BASE=

# Optional mobile/legacy integrations. Leave blank in local dev.
RevenueCatAPIKey=
AMPLITUDE=
CLARITY_PROJECT_ID=
ONESIGNAL_APP_ID=
APPSFLYER_DEV_KEY=
