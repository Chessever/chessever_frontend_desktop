install! 'cocoapods', :disable_input_output_paths => true

# Uncomment this line to define a global platform for your project
platform :ios, '16.1'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerUITests' do
    inherit! :complete
  end
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# target 'ChessEverLiveActivity' do
#   use_frameworks!
#   pod 'OneSignalXCFramework/OneSignalLiveActivities', '>= 5.0.0', '< 6.0'
# end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.1'
    end

  end

  # Xcode 16+ / clang 21 regression: inline asm `.incbin` in Stockfish's
  # NNUE loader loses its -I search path when combined with -flto=full at
  # link-time codegen, so device Release builds fail with
  # "Could not find incbin file 'nn-*.nnue'". The stockfish pod's flags live
  # in its xcconfig files (not the pbxproj), so patch those directly: strip
  # LTO and forward the include path to the integrated assembler.
  stockfish_xcconfig_dir = File.join(installer.sandbox.target_support_files_root, 'stockfish')
  if File.directory?(stockfish_xcconfig_dir)
    Dir.glob(File.join(stockfish_xcconfig_dir, 'stockfish.*.xcconfig')).each do |path|
      contents = File.read(path)
      patched = contents.gsub(/\s-flto(?:=full|=thin)?\b/, '')
      extra = ' -Wa,-I,"${PODS_TARGET_SRCROOT}/Stockfish/src"'
      patched = patched.gsub(/^(OTHER_CPLUSPLUSFLAGS(?:\[[^\]]+\])?\s*=.*)$/) do |line|
        line.include?(extra.strip) ? line : "#{line}#{extra}"
      end
      File.write(path, patched) if patched != contents
    end
  end
end
