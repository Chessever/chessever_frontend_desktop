<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox off — see DebugProfile.entitlements for the full reason. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<!-- Notarization rejects any binary that "requests" get-task-allow.
	     Xcode auto-injects this entitlement during the build phase even on
	     Release configs; pinning it to false here overrides the injected
	     value when codesign re-runs in our post-publish re-sign pass. -->
	<key>com.apple.security.get-task-allow</key>
	<false/>
	<!-- Outbound HTTPS to Google, Supabase, Lichess, etc. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Bind 127.0.0.1 for the OAuth loopback flow -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Associated domains let macOS deliver chessever.com universal links
	     (for example /broadcast/<slug>/<id>) to the desktop app when the
	     website's apple-app-site-association file includes this bundle/team. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:chessever.com</string>
		<string>applinks:www.chessever.com</string>
	</array>
	<!-- Sign in with Apple intentionally omitted: the Developer ID
	     provisioning profile required to grant this entitlement can only
	     be issued by the Apple Developer account holder. The desktop app
	     therefore uses Supabase-hosted Apple OAuth through a loopback
	     callback instead of the native AuthenticationServices sheet. -->
</dict>
</plist>
